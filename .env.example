# App mode: telegram (default) or cli (terminal testing)
APP_MODE=telegram

# Telegram bot token from @BotFather (required unless APP_MODE=cli)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=rpg
DB_SSLMODE=disable

# Ollama scene generation
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
